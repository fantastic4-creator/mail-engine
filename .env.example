# Copy to .env and fill in values. Never commit .env to git.

# ── Local development — in-memory store + Mailpit (docker-compose up mailpit) ─
MAIL_ENGINE_DELIVERY_MODE=smtp
MAIL_ENGINE_STORAGE_MODE=in-memory
MAIL_ENGINE_SMTP_HOST=localhost
MAIL_ENGINE_SMTP_PORT=1025

# ── Local development — Postgres store (docker-compose up) ───────────────────
# MAIL_ENGINE_DELIVERY_MODE=smtp
# MAIL_ENGINE_STORAGE_MODE=postgres
# MAIL_ENGINE_SMTP_HOST=localhost
# MAIL_ENGINE_SMTP_PORT=1025
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/mailengine
# SPRING_DATASOURCE_USERNAME=mailengine
# SPRING_DATASOURCE_PASSWORD=mailengine

# ── Production (EC2 + RDS) ───────────────────────────────────────────────────
# MAIL_ENGINE_DELIVERY_MODE=smtp
# MAIL_ENGINE_STORAGE_MODE=postgres
# MAIL_ENGINE_SMTP_HOST=localhost
# MAIL_ENGINE_SMTP_PORT=25
# SPRING_DATASOURCE_URL=jdbc:postgresql://<RDS_ENDPOINT>:5432/mailengine
# SPRING_DATASOURCE_USERNAME=mailengine
# SPRING_DATASOURCE_PASSWORD=<from scripts/.state DB_PASSWORD>
